# Optional environment overrides. Nothing auto-loads this file — the normal way to
# configure fourchan-local is `4cl init` / `4cl boards` / `4cl config`. These vars
# only matter if you export them (or prefix a command) to override a default, e.g.
# for a manual `python -m fourchan_local.poller` run. All are optional.

# SQLite data file. Blank = OS data dir (~/.local/share/fourchan-local/archive.db
# on Linux). One WAL file; the scraper writes, the web UI reads.
FOURCHAN_DB=
# Content-addressed media store dir. Blank = <data dir>/media.
MEDIA_STORE=

# Board codes (no slashes), comma-separated, or the literal "all". Normally set via
# `4cl boards add …`; this only overrides a manual poller run.
BOARDS=all
# Seconds between full poll cycles of all boards.
POLL_INTERVAL=60
# Global request rate cap to a.4cdn.org. 4chan rule: <= 1 req/sec. Do not raise.
REQ_PER_SEC=1
# Grace window a 404'd, unpinned thread stays browsable before the GC purges it.
PURGE_GRACE=86400

# --- media ---
# Boards whose file BYTES are never downloaded (manifest still captured). Normally
# set via `4cl config blocklist`. Blank here means "unset" -> the built-in default
# list (b,soc,r,hc,gif,s,t — photographic/CSAM-risk boards) applies.
MEDIA_BLOCKLIST=
# Worker phase: thumbs (cheap, ~30-60 GB/mo all boards) | full (images, ~1.5-2 TB/mo).
# Normally set via `4cl config media`.
MEDIA_PHASE=thumbs
# Full phase only: images (jpg/png/gif, skip webm/mp4) | all.
MEDIA_TYPES=images
# Media CDN (i.4cdn.org) rate cap. Keep <= 1; it's a separate host from the API.
REQ_PER_SEC_MEDIA=1
# Seconds the worker sleeps when the queue is drained (idle back-off).
MEDIA_IDLE_SLEEP=300
# 404 grace: retry a missing file every MEDIA_404_BACKOFF secs, up to
# MEDIA_404_MAX_ATTEMPTS times, before tombstoning it (guards transient 404s).
MEDIA_404_BACKOFF=21600
MEDIA_404_MAX_ATTEMPTS=2
